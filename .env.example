# Required in all environments
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# WebAuthn defaults (local development)
WEBAUTHN_RP_NAME=Todo App
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost

# Production example (set these in Railway Variables, not in git)
# In production, WEBAUTHN_ORIGIN and WEBAUTHN_RP_ID are required.
# WEBAUTHN_ORIGIN=https://your-app-name.up.railway.app
# WEBAUTHN_RP_ID=your-app-name.up.railway.app
